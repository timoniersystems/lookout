# Docker Build Configuration
# Copy this file to .env and customize as needed

# Go version for building the application
# See available versions: https://hub.docker.com/_/golang/tags
GO_VERSION=1.23.5

# Alpine Linux version for runtime container
# See available versions: https://hub.docker.com/_/alpine/tags
ALPINE_VERSION=3.21

# Trivy scanner version
# See releases: https://github.com/aquasecurity/trivy/releases
TRIVY_VERSION=0.58.2

# NVD API Key (HIGHLY RECOMMENDED to avoid rate limiting)
# Get your key from: https://nvd.nist.gov/developers/request-an-api-key
# Without key: 5 requests per 30 seconds (very slow for SBOM processing)
# With key: 50 requests per 30 seconds (10x faster)
NVD_API_KEY=your-api-key-here

# Application Configuration
DGRAPH_HOST=dgraph-alpha
DGRAPH_PORT=9080
